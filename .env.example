# CGM Get Agent — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.
# Run `make install` to generate this automatically.

# -------------------------------------------------------------------
# Dexcom Developer App Credentials
# Register YOUR OWN app at https://developer.dexcom.com to obtain these.
# Do not use anyone else's credentials.
# -------------------------------------------------------------------
GA_DEXCOM_CLIENT_ID=YOUR_CLIENT_ID
GA_DEXCOM_CLIENT_SECRET=YOUR_CLIENT_SECRET

# Dexcom environment: "sandbox" for simulated data, "production" for live CGM.
GA_DEXCOM_ENV=production

# -------------------------------------------------------------------
# Encryption
# AES-256-GCM key for OAuth token storage (32 bytes, hex-encoded).
# Auto-generated by `make install`. To generate manually: openssl rand -hex 32
# -------------------------------------------------------------------
GA_ENCRYPTION_KEY=GENERATED_BY_INSTALL_SCRIPT

# -------------------------------------------------------------------
# Server configuration
# -------------------------------------------------------------------

# HTTP listen port. Must match the Redirect URI in your Dexcom developer app.
GA_SERVER_PORT=8090

# OAuth redirect URI — must match Dexcom app config and GA_SERVER_PORT.
GA_DEXCOM_REDIRECT_URI=http://localhost:8090/callback

# MCP transport: "sse" for Claude Desktop/ChatGPT, "stdio" for CLI.
GA_MCP_TRANSPORT=sse

# Log verbosity: 1=ERROR (quiet), 2=INFO (default), 3=DEBUG (diagnostic).
GA_LOG_LEVEL=2

# -------------------------------------------------------------------
# Storage paths (defaults shown — only set to override)
# -------------------------------------------------------------------
# GA_DB_PATH=/data/data.db
# GA_TOKEN_PATH=/data/tokens.enc
# GA_CONFIG_PATH=/data/config.yaml
